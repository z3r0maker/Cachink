{
  "name": "@cachink/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "description": "Cachink mobile app (iOS and Android tablets). See ./SETUP.md.",
  "scripts": {
    "bundle:check": "bash scripts/bundle-check.sh",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "maestro test maestro/flows --config maestro/.maestro-config.yaml",
    "lint": "eslint 'src/**/*.{ts,tsx}' --config ../../eslint.config.js --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .expo .turbo node_modules"
  },
  "dependencies": {
    "@cachink/application": "workspace:^",
    "@cachink/data": "workspace:^",
    "@cachink/domain": "workspace:^",
    "@cachink/sync-cloud": "workspace:^",
    "@cachink/ui": "workspace:^",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/metro-runtime": "~55.0.10",
    "@hookform/resolvers": "^5.2.2",
    "@journeyapps/react-native-quick-sqlite": "^2.5.2",
    "@powersync/common": "^1.52.0",
    "@powersync/react-native": "^1.34.0",
    "@sentry/react-native": "^8.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "@tamagui/config": "2.0.0-rc.41",
    "@tamagui/core": "2.0.0-rc.41",
    "@tamagui/web": "2.0.0-rc.41",
    "@tanstack/react-query": "^5.100.1",
    "dinero.js": "^2.0.2",
    "expo": "~55.0.17",
    "expo-camera": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-localization": "~55.0.13",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "hoist-non-react-statics": "^3.3.2",
    "i18next": "^26.0.7",
    "lucide-react-native": "^1.11.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.73.1",
    "react-i18next": "^17.0.4",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "~4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "~13.16.1",
    "ulid": "^3.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~5.9.2"
  }
}
