{
  "name": "@cachink/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cachink desktop app (Windows and macOS) via Tauri 2. See ./SETUP.md.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "echo 'Playwright setup lands in Phase 1C-M12.' && exit 0",
    "lint": "eslint 'src/**/*.{ts,tsx}' --config ../../eslint.config.js --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules src-tauri/target"
  },
  "dependencies": {
    "@cachink/application": "workspace:*",
    "@cachink/data": "workspace:*",
    "@cachink/domain": "workspace:*",
    "@cachink/ui": "workspace:*",
    "@tamagui/config": "2.0.0-rc.41",
    "@tamagui/core": "2.0.0-rc.41",
    "@tamagui/web": "2.0.0-rc.41",
    "@tanstack/react-query": "^5.100.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2",
    "dinero.js": "^2.0.2",
    "i18next": "^26.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.73.1",
    "react-i18next": "^17.0.4",
    "ulid": "^3.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.4"
  }
}
