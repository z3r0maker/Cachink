{
  "name": "@cachink/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cachink desktop app (Windows and macOS) via Tauri 2. See ./SETUP.md.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:check": "cd src-tauri && cargo check --locked",
    "tauri:test": "cd src-tauri && cargo test --locked",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:lan": "playwright test --config=playwright.config.ts lan-",
    "test:cloud": "playwright test --config=playwright.config.ts cloud-",
    "lint": "eslint 'src/**/*.{ts,tsx}' --config ../../eslint.config.js --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules src-tauri/target"
  },
  "dependencies": {
    "@cachink/application": "workspace:*",
    "@cachink/data": "workspace:*",
    "@cachink/domain": "workspace:*",
    "@cachink/ui": "workspace:*",
    "@journeyapps/wa-sqlite": "^1.7.0",
    "@powersync/common": "^1.52.0",
    "@powersync/web": "^1.37.2",
    "@supabase/supabase-js": "^2.49.0",
    "@tamagui/config": "2.0.0-rc.41",
    "@tamagui/core": "2.0.0-rc.41",
    "@tamagui/web": "2.0.0-rc.41",
    "@tanstack/react-query": "^5.100.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2",
    "dinero.js": "^2.0.2",
    "i18next": "^26.0.7",
    "lucide-react": "^1.11.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.73.1",
    "@hookform/resolvers": "^5.2.2",
    "react-i18next": "^17.0.4",
    "ulid": "^3.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.4"
  }
}
