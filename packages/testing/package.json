{
  "name": "@cachink/testing",
  "version": "0.0.0",
  "private": true,
  "description": "Shared testing utilities, fixtures, and in-memory repository implementations.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' --config ../../eslint.config.js",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --config ../../eslint.config.js --fix",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@cachink/data": "workspace:*",
    "@cachink/domain": "workspace:*",
    "vitest": "^3.0.0"
  },
  "devDependencies": {
    "@cachink/config": "workspace:*",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
