{
  "name": "@cachink/testing",
  "version": "0.0.0",
  "private": true,
  "description": "Shared testing utilities, fixtures, and in-memory repository implementations.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' --config ../../eslint.config.js",
    "lint:fix": "eslint 'src/**/*.ts' --config ../../eslint.config.js --fix",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@cachink/data": "workspace:*",
    "@cachink/domain": "workspace:*"
  },
  "devDependencies": {
    "@cachink/config": "workspace:*",
    "typescript": "^5.7.0"
  }
}
