{
  "name": "@cachink/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared cross-platform UI components and brand tokens. Tamagui-based.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme.ts",
    "./components": "./src/components/index.ts",
    "./screens": "./src/screens/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./database": "./src/database/index.ts",
    "./app-config": "./src/app-config/index.ts",
    "./app": "./src/app/index.ts",
    "./share": "./src/share/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./notifications": "./src/notifications/index.ts",
    "./sync": "./src/sync/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' --config ../../eslint.config.js",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' --config ../../eslint.config.js --fix",
    "clean": "rm -rf dist .turbo storybook-static playwright-report test-results",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "test:visual": "playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "@cachink/application": "workspace:*",
