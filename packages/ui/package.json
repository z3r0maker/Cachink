{
  "name": "@cachink/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared cross-platform UI components and brand tokens. Tamagui-based.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme.ts",
    "./components": "./src/components/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./database": "./src/database/index.ts",
    "./hooks": "./src/hooks/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' --config ../../eslint.config.js",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}' --config ../../eslint.config.js --fix",
    "clean": "rm -rf dist .turbo storybook-static playwright-report test-results",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "test:visual": "playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "@cachink/application": "workspace:*",
    "@cachink/data": "workspace:*",
    "@cachink/domain": "workspace:*",
    "drizzle-orm": "^0.45.0"
  },
  "peerDependencies": {
    "@tamagui/core": "2.0.0-rc.41",
    "@tamagui/dialog": "2.0.0-rc.41",
    "@tamagui/input": "2.0.0-rc.41",
    "@tamagui/web": "2.0.0-rc.41",
    "expo-sqlite": "~55",
    "i18next": "^26",
    "react": "^19",
    "react-i18next": "^17",
    "react-native": ">=0.83"
  },
  "peerDependenciesMeta": {
    "expo-sqlite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cachink/config": "workspace:*",
    "@playwright/test": "^1.59.1",
    "expo-sqlite": "~55.0.15",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react-native-web-vite": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tamagui/core": "2.0.0-rc.41",
    "@tamagui/dialog": "2.0.0-rc.41",
    "@tamagui/input": "2.0.0-rc.41",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.0.0",
    "i18next": "^26",
    "jsdom": "^29",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17",
    "react-native": "0.83.6",
    "react-native-web": "^0.21.0",
    "storybook": "^10.3.5",
    "typescript": "^5.7.0",
    "vite": "^7.0.4",
    "vitest": "^3.0.0"
  }
}
