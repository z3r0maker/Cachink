{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../config/tsconfig.lib.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "tests"],
  "references": [{ "path": "../domain" }, { "path": "../application" }]
}
