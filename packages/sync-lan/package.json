{
  "name": "@cachink/sync-lan",
  "version": "0.0.0",
  "private": true,
  "description": "First-party LAN sync client. Bundled with the Tauri desktop server. Phase 1D.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./protocol": "./src/protocol/index.ts",
    "./client": "./src/client/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' --config ../../eslint.config.js",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --config ../../eslint.config.js --fix",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@cachink/data": "workspace:*",
    "@cachink/domain": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cachink/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^3.0.0",
    "better-sqlite3": "^11.8.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
