{
  "name": "@cachink/domain",
  "version": "0.0.0",
  "private": true,
  "description": "Pure business logic. No React, no RN, no SQLite, no IO. Unit-testable in milliseconds.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./money": "./src/money/index.ts",
    "./ids": "./src/ids/index.ts",
    "./dates": "./src/dates/index.ts",
    "./format": "./src/format/index.ts",
    "./entities": "./src/entities/index.ts",
    "./financials": "./src/financials/index.ts",
    "./comprobante": "./src/comprobante/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' --config ../../eslint.config.js",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --config ../../eslint.config.js --fix",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "ulid": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cachink/config": "workspace:*",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
